{
  "name": "volponi-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/serve-static.mjs site --port 8080",
    "build": "node scripts/build-static.mjs",
    "build:dev": "node scripts/build-static.mjs",
    "lint": "node scripts/check-static.mjs",
    "preview": "node scripts/serve-static.mjs dist",
    "auto-fix": "npm run ci:verify",
    "pr:governance": "node scripts/check-static.mjs",
    "typecheck": "node scripts/check-static.mjs --typecheck",
    "ci:verify": "npm run lint && npm run typecheck && npm run build",
    "ship": "npm ci && npm run ci:verify",
    "healthcheck:runtime": "node scripts/healthcheck-static.mjs",
    "healthcheck:runtime:full": "npm run healthcheck:runtime && npm run ci:verify",
    "vercel:build": "./scripts/vercel-guard.sh"
  }
}
